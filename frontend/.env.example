# Environment Variables for Frontend

# App base URL (used by Auth0 and server-side code)
APP_BASE_URL=http://localhost:3000

# Backend API URL
# API_BASE_URL is used server-side (Next.js API routes / SSR) — use internal Docker network in Docker
API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_API_URL is baked into the client bundle at build time — must be browser-reachable
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_ISSUER_BASE_URL=https://your-tenant.eu.auth0.com
AUTH0_BASE_URL=http://localhost:3000
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_SECRET=your-32-char-random-secret-use-openssl-rand-base64-32
AUTH0_REDIRECT_URI=http://localhost:3000/auth/callback
AUTH0_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/
AUTH0_SCOPE=openid profile email offline_access
AUTH0_AUDIENCE=https://api.slodi.is

# Resend (email) configuration
RESEND_API_KEY=re_your_api_key
